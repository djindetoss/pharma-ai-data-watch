# ── API Keys ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# The .env file is gitignored and never committed.

# NewsAPI — https://newsapi.org/register (free, no credit card)
# 1,000 requests/day on the free developer tier
NEWSAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Anthropic Claude — https://console.anthropic.com/
# Used to clean up raw PubMed/bioRxiv abstracts into readable excerpts
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: NCBI API key — https://www.ncbi.nlm.nih.gov/account/
# Increases PubMed rate limit from 3 to 10 requests/second (free)
NCBI_API_KEY=
