# ── API Keys ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# The .env file is gitignored and never committed.

# Perplexity AI — https://www.perplexity.ai/settings/api
# Used for live web search with citations (sonar-pro model)
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Anthropic Claude — https://console.anthropic.com/
# Used for excerpt quality improvement and relevance scoring
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: NCBI API key — https://www.ncbi.nlm.nih.gov/account/
# Increases PubMed rate limit from 3 to 10 requests/second
NCBI_API_KEY=
