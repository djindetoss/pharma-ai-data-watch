{
  "_comment": "Pharma AI & Data Watch — ingestion pipeline configuration",

  "output": {
    "articles_json": "../portal/js/articles.json",
    "drafts_dir": "drafts",
    "processed_ids_file": "processed/seen_ids.json"
  },

  "newsapi": {
    "enabled": true,
    "max_results_per_query": 10,
    "_comment": "Free tier at newsapi.org — 1,000 requests/day, no credit card needed"
  },

  "claude_enhancer": {
    "enabled": true,
    "max_articles_to_enhance": 20,
    "_comment": "Uses claude-haiku to clean up PubMed/bioRxiv raw abstracts"
  },

  "settings": {
    "max_articles_per_source": 10,
    "auto_approve_threshold": 3,
    "min_relevance_score": 1,
    "max_total_articles": 100,
    "days_lookback": 7
  },

  "pubmed": {
    "enabled": true,
    "base_url": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils",
    "search_queries": [
      { "q": "artificial intelligence drug discovery OR drug design OR lead optimization",    "topic": "drug-discovery" },
      { "q": "machine learning AlphaFold protein structure prediction pharmaceutical",         "topic": "drug-discovery" },
      { "q": "deep learning ADMET toxicity prediction drug development",                       "topic": "drug-discovery" },
      { "q": "machine learning regulatory EMA FDA approval pharmaceutical",                    "topic": "regulatory"     },
      { "q": "AI regulatory science ICH reflection paper guideline",                           "topic": "regulatory"     },
      { "q": "artificial intelligence clinical trial adaptive decentralised pharmacovigilance", "topic": "clinical-ai"    },
      { "q": "natural language processing pharmacovigilance adverse event signal detection",    "topic": "clinical-ai"    },
      { "q": "EHDS European Health Data Space secondary use health data governance regulation",  "topic": "data-governance" },
      { "q": "IDMP SPOR FHIR OMOP data standard interoperability pharmaceutical regulatory",   "topic": "data-governance" },
      { "q": "DARWIN EU real-world data network federated analysis pharmacoepidemiology EMA",   "topic": "data-governance" },
      { "q": "real-world evidence data quality fit-for-purpose regulatory EMA FDA",            "topic": "data-governance" },
      { "q": "federated learning privacy-preserving health data pseudonymisation pharmaceutical", "topic": "data-governance" },
      { "q": "patient registry disease registry data governance rare disease EMA",              "topic": "data-governance" }
    ],
    "max_results_per_query": 5,
    "db": "pubmed"
  },

  "biorxiv": {
    "enabled": true,
    "base_url": "https://api.biorxiv.org/details",
    "search_terms": [
      "artificial intelligence drug",
      "machine learning pharmaceutical",
      "deep learning clinical"
    ],
    "server": "biorxiv"
  },

  "rss_sources": {
    "enabled": true,
    "feeds": [
      {
        "url": "https://www.ema.europa.eu/en/feeds/latest-news",
        "name": "EMA",
        "type": "news",
        "badge": "Regulatory",
        "topic": "regulatory",
        "auto_approve": true
      },
      {
        "url": "https://www.fda.gov/about-fda/contact-fda/stay-informed/rss-feeds/press-releases/rss.xml",
        "name": "FDA",
        "type": "news",
        "badge": "Regulatory",
        "topic": "regulatory",
        "auto_approve": true
      },
      {
        "url": "https://www.who.int/feeds/entity/mediacentre/news/en/rss.xml",
        "name": "WHO",
        "type": "news",
        "badge": "Policy",
        "topic": "regulatory",
        "auto_approve": false
      }
    ]
  },

  "event_sources": {
    "enabled": false,
    "_comment": "All tested RSS event feeds return 404. Events are sourced via 4 dedicated NewsAPI queries instead (webinars, conferences, AI governance events, health data events). Re-enable with valid RSS URLs if available.",
    "feeds": []
  },

  "data_sources": {
    "enabled": true,
    "_comment": "Curated feeds specifically for the Data tab: interoperability, FHIR, EHR, data standards, health data policy.",
    "feeds": [
      {
        "url": "https://www.healthcareitnews.com/rss.xml",
        "name": "Healthcare IT News",
        "type": "news",
        "badge": "Data",
        "topic": "data-governance",
        "auto_approve": false
      },
      {
        "url": "https://www.statnews.com/feed/",
        "name": "STAT News",
        "type": "news",
        "badge": "Data",
        "topic": "data-governance",
        "auto_approve": false
      }
    ]
  },

  "ai_news_sources": {
    "enabled": true,
    "feeds": [
      {
        "url": "https://techcrunch.com/category/artificial-intelligence/feed/",
        "name": "TechCrunch AI",
        "type": "ainews",
        "badge": "Tech"
      },
      {
        "url": "https://www.technologyreview.com/feed/",
        "name": "MIT Technology Review",
        "type": "ainews",
        "badge": "Research"
      },
      {
        "url": "https://www.theverge.com/rss/ai-artificial-intelligence/rss.xml",
        "name": "The Verge",
        "type": "ainews",
        "badge": "Tech"
      },
      {
        "url": "https://feeds.nature.com/natmachintell/rss/current",
        "name": "Nature Machine Intelligence",
        "type": "ainews",
        "badge": "Research"
      },
      {
        "url": "https://venturebeat.com/category/ai/feed/",
        "name": "VentureBeat AI",
        "type": "ainews",
        "badge": "Tech"
      }
    ]
  },

  "pharma_keywords": [
    "drug discovery", "drug development", "pharmaceutical", "medicinal",
    "clinical trial", "regulatory", "EMA", "FDA", "CHMP", "pharmacovigilance",
    "biomarker", "therapeutics", "molecule", "compound", "protein",
    "target identification", "lead optimization", "ADMET", "toxicity",
    "clinical", "patient", "disease", "treatment", "therapy", "medicine",
    "health", "biotech", "biopharma", "precision medicine", "genomics",
    "proteomics", "EHDS", "real-world evidence", "RWE", "adverse event"
  ],

  "ai_keywords": [
    "artificial intelligence", "machine learning", "deep learning", "neural network",
    "large language model", "LLM", "transformer", "generative AI", "foundation model",
    "reinforcement learning", "natural language processing", "NLP",
    "computer vision", "graph neural network", "GNN", "diffusion model",
    "AlphaFold", "ChatGPT", "GPT", "Claude", "Gemini", "Llama"
  ]
}
